VITE_API_URL=https://api.empowered.vote
VITE_TREASURY_URL=https://financials.empowered.vote

# PostHog analytics project key. REQUIRED in deployed (preview/production)
# environments — when unset, @empoweredvote/analytics runs in no-op mode and
# nothing is sent. Leave it UNSET locally so dev traffic stays out of prod.
VITE_POSTHOG_KEY=
